<Window x:Class="TimeManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TimeManagementApp.ViewModels"
        Title="Time Management App" Height="600" Width="800">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Add Module Section -->
        <GroupBox Header="Add Module" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10">
                <StackPanel Margin="5">
                    <TextBlock Text="Code" />
                    <TextBox Width="80" Text="{Binding NewModuleCode, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Name" />
                    <TextBox Width="120" Text="{Binding NewModuleName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Credits" />
                    <TextBox Width="60" Text="{Binding NewModuleCredits, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Class Hrs/Week" />
                    <TextBox Width="60" Text="{Binding NewModuleClassHours, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Weeks" />
                    <TextBox Width="60" Text="{Binding NewModuleWeeks, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Start Date" />
                    <DatePicker Width="130" SelectedDate="{Binding NewModuleStartDate}" />
                </StackPanel>
                <Button Content="Add" Margin="5,20,5,0" Command="{Binding AddModuleCommand}" />
            </StackPanel>
        </GroupBox>

        <!-- Modules List -->
        <GroupBox Header="Modules" Grid.Row="1" Margin="0,0,0,10">
            <ListView ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule}" Margin="10">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="60"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="100"/>
                        <GridViewColumn Header="Credits" DisplayMemberBinding="{Binding Credits}" Width="60"/>
                        <GridViewColumn Header="Class Hours" DisplayMemberBinding="{Binding ClassHoursPW}" Width="80"/>
                        <GridViewColumn Header="Self-Study/Week" DisplayMemberBinding="{Binding SelfStudyHoursPerWeek}" Width="100"/>
                        <GridViewColumn Header="Remaining This Week" DisplayMemberBinding="{Binding RemainingSelfStudyHoursThisWeek}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Record Study Time Section -->
        <GroupBox Header="Record Study Time" Grid.Row="2" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10">
                <StackPanel Margin="5">
                    <TextBlock Text="Hours Studied" />
                    <TextBox Width="100" Text="{Binding NewStudyHours, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Study Date" />
                    <DatePicker Width="140" SelectedDate="{Binding NewStudyDate}" />
                </StackPanel>
                <Button Content="Record" Margin="5,20,5,0" Command="{Binding RecordStudyCommand}" />
            </StackPanel>
        </GroupBox>

        <!-- Study Records -->
        <GroupBox Header="Study Records" Grid.Row="3">
            <ListView ItemsSource="{Binding SelectedModule.StudyTimeRecords}" Margin="10">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Date" DisplayMemberBinding="{Binding StudyDate}" Width="150"/>
                        <GridViewColumn Header="Hours" DisplayMemberBinding="{Binding HoursSpent}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</Window>
