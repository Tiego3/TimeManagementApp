<Window x:Class="TimeManagementApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TimeManagementApp.ViewModels"
        Title="Time Management App" Height="800" Width="1200">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <!-- Module Input Fields -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">
            <TextBox Text="{Binding ModuleCode, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Text="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Text="{Binding Credits, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Text="{Binding ClassHoursPerWeek, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Text="{Binding WeeksInSemester, UpdateSourceTrigger=PropertyChanged}" />
            <DatePicker SelectedDate="{Binding StartDate}" />
            <Button Content="Add Module" Command="{Binding AddModuleCommand}" />
        </StackPanel>

        <!-- Modules List -->
        <ListView ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule}" DisplayMemberPath="Name" />

        <!-- Study Time Records -->
        <StackPanel Orientation="Vertical" Margin="0,10,0,0">
            <DatePicker SelectedDate="{Binding StudyDate}" />
            <TextBox Text="{Binding HoursSpent, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Record Study Hours" Command="{Binding RecordStudyHoursCommand}" />
        </StackPanel>

        <ListView ItemsSource="{Binding StudyTimeRecords}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Date" DisplayMemberBinding="{Binding StudyDate}" />
                    <GridViewColumn Header="Hours Spent" DisplayMemberBinding="{Binding HoursSpent}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
