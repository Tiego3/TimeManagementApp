<Page x:Class="TimeManagementApp.Views.AddModulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddModulePage">

    <StackPanel Margin="20" Width="350">

        <TextBlock Text="Add Module" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="Module Code:" />
        <TextBox x:Name="CodeBox" Margin="0,0,0,10"/>

        <TextBlock Text="Module Name:" />
        <TextBox x:Name="NameBox" Margin="0,0,0,10"/>

        <TextBlock Text="Credits:" />
        <TextBox x:Name="CreditsBox" Margin="0,0,0,10"/>

        <TextBlock Text="Class Hours Per Week:" />
        <TextBox x:Name="ClassHoursBox" Margin="0,0,0,10"/>

        <Button Content="Add Module" Click="AddModule_Click" Margin="0,10"/>

        <ListView x:Name="ModuleListView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" />
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Credits" DisplayMemberBinding="{Binding Credits}" />
                    <GridViewColumn Header="Class Hours" DisplayMemberBinding="{Binding ClassHoursPerWeek}" />
                    <GridViewColumn Header="Self Study / Week" DisplayMemberBinding="{Binding SelfStudyHoursPerWeek}" />
                    <GridViewColumn Header="Remaining This Week" DisplayMemberBinding="{Binding RemainingHoursThisWeek}" />
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Page>
