<Window x:Class="TimeManagementApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeManagementApp.Views"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBox x:Name="UsernameBox" PlaceholderText="Username" Margin="0,0,0,10"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>
        <Button Content="Login" Click="Login_Click"/>
    </StackPanel>
</Window>
