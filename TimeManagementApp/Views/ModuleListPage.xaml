<Page x:Class="TimeManagementApp.Views.ModulesListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:TimeManagementApp.Views"
      Title="ModulesListPage">

    <Grid Margin="20">
        <TextBlock Text="Your Modules" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListView Name="ModulesListView" ItemsSource="{Binding Modules}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="100"/>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Credits" DisplayMemberBinding="{Binding Credits}" Width="80"/>
                    <GridViewColumn Header="Class Hours/Wk" DisplayMemberBinding="{Binding ClassHoursPW}" Width="100"/>
                    <GridViewColumn Header="Self-Study Hours/Wk" DisplayMemberBinding="{Binding SelfStudyHoursPerWeek}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
