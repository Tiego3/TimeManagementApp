<Window x:Class="TimeManagementApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="New Username:" />
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="New Password:" Margin="0 10 0 0"/>
            <PasswordBox Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"/>

            <Button Content="Register" Margin="0 20 0 0" Width="100" HorizontalAlignment="Center" Command="{Binding RegisterCommand}" />
        </StackPanel>
    </Grid>
</Window>
